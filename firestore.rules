rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        // 1. SUPER ADMIN: Siempre tiene acceso garantizado
        request.auth.token.email == "hmalldm95@gmail.com" ||
        
        // 2. ADMINS POR UID
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         
        // 3. ADMINS POR CORREO
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin')
      );
    }

    // NUEVA: Verifica si es un ayudante con sesión activa por PIN
    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/staff_sessions/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/staff_sessions/$(request.auth.uid)).data.expires > request.time;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /colecciones/{coleccionId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /categorias/{categoriaId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /productos/{productoId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- CONFIGURACIÓN DE ACCESO (PIN) ---
    match /orders/settings_access {
      allow read: if true; // Necesario para verificar el PIN al entrar
      allow write: if isAdmin();
    }

    // --- SESIONES DE AYUDANTES ---
    match /staff_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && request.auth.uid == sessionId;
    }

    // --- PEDIDOS (UNIFICADOS) ---
    match /orders/{orderId} {
      allow create: if true; 
      allow read, update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      allow read, update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
