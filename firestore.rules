rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        ("email" in request.auth.token && request.auth.token.email == "hmalldm95@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/staff_sessions/$(request.auth.uid));
    }

    function canManageOrders() {
      return isAdmin() || isStaff();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Publicly readable catalogs
    match /colecciones/{id} { allow read: if true; allow write: if isAdmin(); }
    match /categorias/{id} { allow read: if true; allow write: if isAdmin(); }
    match /productos/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }

    // Access settings (PIN)
    match /orders/settings_access {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Staff sessions
    match /staff_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && request.auth.uid == sessionId;
    }

    // Orders
    match /orders/{orderId} {
      allow create: if true;
      allow read: if canManageOrders() || orderId == 'settings_access';
      allow update, delete: if canManageOrders() && orderId != 'settings_access';
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      allow read, update, delete: if canManageOrders();
    }

    // Users
    match /users/{userId} {
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
